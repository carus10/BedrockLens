{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": ["src/renderer/src/**/*", "src/renderer/src/**/*.d.ts"],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@shared/*": ["src/shared/*"],
      "@/*": ["src/renderer/src/*"]
    }
  }
}
